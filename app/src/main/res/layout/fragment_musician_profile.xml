<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="32dp">

            <ImageView
                android:id="@+id/heroImage"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:scaleType="centerCrop"
                android:src="@drawable/mariachi"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.cardview.widget.CardView
                android:id="@+id/profileCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="-40dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:layout_constraintTop_toBottomOf="@id/heroImage">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/artistName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cargando..."
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvVerified"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="✅"
                            android:visibility="gone"
                            android:textSize="18sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="📍 Cargando ubicación..."
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvHourlyRate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="💵 Cargando tarifa..."
                        android:textColor="?attr/colorPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCoverageNotes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="🚗 Cobertura: ..."
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="14sp"
                        android:visibility="gone"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="20dp"
                        android:weightSum="2">

                        <TextView
                            android:id="@+id/btnTabDescription"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Acerca de"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:textColor="?attr/colorOnSurface"
                            android:paddingBottom="8dp" />

                        <TextView
                            android:id="@+id/btnTabContact"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Contacto"
                            android:textSize="16sp"
                            android:gravity="center"
                            android:textColor="?attr/colorOnSurface"
                            android:alpha="0.5"
                            android:paddingBottom="8dp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutline"
                        android:alpha="0.3"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:id="@+id/layoutDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Cargando detalles..."
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:lineSpacingExtra="4dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutContactInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"> <TextView
                        android:id="@+id/tvNoContact"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Este músico no ha agregado información de contacto."
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textStyle="italic"
                        android:visibility="gone" />

                        <TextView
                            android:id="@+id/tvPhone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📱 Teléfono: "
                            android:textColor="?attr/colorPrimary"
                            android:textStyle="bold"
                            android:visibility="gone"
                            android:paddingVertical="4dp"/>

                        <TextView
                            android:id="@+id/tvInstagram"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📸 Instagram: "
                            android:textColor="#E1306C"
                            android:visibility="gone"
                            android:paddingVertical="4dp"/>

                        <TextView
                            android:id="@+id/tvFacebook"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📘 Facebook: "
                            android:textColor="#1877F2"
                            android:visibility="gone"
                            android:paddingVertical="4dp"/>

                        <TextView
                            android:id="@+id/tvYoutube"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="▶️ YouTube: "
                            android:textColor="#FF0000"
                            android:visibility="gone"
                            android:paddingVertical="4dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:gravity="end"
                        android:orientation="horizontal">

                        <ImageButton
                            android:id="@+id/btnFav"
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:background="@drawable/bg_secondary_button"
                            android:src="@drawable/ic_favorite_border"
                            app:tint="?attr/colorPrimary" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/labelAvail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:text="Disponibilidad Próxima"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                app:layout_constraintTop_toBottomOf="@id/profileCard"
                app:layout_constraintStart_toStartOf="parent"/>

            <HorizontalScrollView
                android:id="@+id/scrollDates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:clipToPadding="false"
                android:scrollbars="none"
                app:layout_constraintTop_toBottomOf="@id/labelAvail">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingTop="8dp"
                    android:orientation="horizontal">
                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Feb 10"
                        app:chipBackgroundColor="#DCFCE7"
                        android:textColor="#166534"
                        app:chipStrokeWidth="0dp"/>
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/labelPhotos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="30dp"
                android:text="Fotos y Videos"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/scrollDates"
                app:layout_constraintStart_toStartOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/md_surface"
        app:itemIconTint="@color/md_onSurfaceVariant"
        app:itemTextColor="@color/md_onSurfaceVariant"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/bottom_nav_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>
